{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>metio/renovate-config"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "git-submodules": {
    "enabled": true
  },
  "customManagers": [
    {
      "description": "The tik workload's default image, pinned in the stage, its catalog annotation, and the generated catalog.json. Matching all three keeps them in lockstep so the check-catalog gate stays green on the bump PR.",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/metio/tik",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "/^workloads/.+\\.libsonnet$/",
        "/^catalog/annotations\\.libsonnet$/",
        "/^catalog/catalog\\.json$/"
      ],
      "matchStrings": [
        "ghcr\\.io/metio/tik:(?<currentValue>[0-9][0-9A-Za-z._-]+)"
      ]
    },
    {
      "description": "The nginx image the examples and docs render with, so the illustrative manifests never pin a stale tag. Placeholder images (ghcr.io/acme/*, ghcr.io/example/*) carry no real tags and are deliberately not matched.",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker.io/nginxinc/nginx-unprivileged",
      "managerFilePatterns": [
        "/^examples/.+\\.jsonnet$/",
        "/^docs/content/.+\\.md$/",
        "/^README\\.md$/"
      ],
      "matchStrings": [
        "docker\\.io/nginxinc/nginx-unprivileged:(?<currentValue>[0-9][0-9A-Za-z._-]+)"
      ]
    },
    {
      "description": "Alpine.js, fetched by gen-docs-data at docs-build time from the pinned version so the assembler page always ships the tracked release.",
      "customType": "regex",
      "datasourceTemplate": "npm",
      "depNameTemplate": "alpinejs",
      "managerFilePatterns": [
        "/^scripts/gen-docs-data\\.sh$/"
      ],
      "matchStrings": [
        "ALPINE_VERSION=(?<currentValue>[0-9][0-9A-Za-z._-]+)"
      ]
    },
    {
      "description": "Operator versions the e2e scenarios install, pinned in hack/smoke/*.sh via a `# renovate:` comment above a `<TOOL>_VERSION=\"...\"` line.",
      "customType": "regex",
      "managerFilePatterns": [
        "/^hack/smoke/.+\\.sh$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\s+[A-Z0-9_]+_VERSION=\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "The Valkey image the valkey workload runs, pinned in its stages, catalog, and README so a bump is a visible Renovate PR that triggers the valkey e2e (not a silently floating tag).",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker.io/valkey/valkey",
      "managerFilePatterns": [
        "/^workloads/valkey/.+\\.libsonnet$/",
        "/^workloads/valkey/README\\.md$/",
        "/^catalog/annotations\\.libsonnet$/",
        "/^catalog/catalog\\.json$/"
      ],
      "matchStrings": [
        "docker\\.io/valkey/valkey:(?<currentValue>[0-9][0-9A-Za-z.-]+)"
      ]
    },
    {
      "description": "The kubectl sidecar image the valkey cache uses for its primary-following labeler.",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker.io/alpine/k8s",
      "managerFilePatterns": [
        "/^workloads/valkey/cache\\.libsonnet$/"
      ],
      "matchStrings": [
        "docker\\.io/alpine/k8s:(?<currentValue>[0-9][0-9A-Za-z.-]+)"
      ]
    },
    {
      "description": "The OpenTelemetry Collector (contrib) image the otel-collector agent runs, pinned in its stage, catalog, and README so a bump is a visible Renovate PR.",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker.io/otel/opentelemetry-collector-contrib",
      "managerFilePatterns": [
        "/^workloads/otel-collector/.+\\.libsonnet$/",
        "/^workloads/otel-collector/README\\.md$/",
        "/^catalog/annotations\\.libsonnet$/",
        "/^catalog/catalog\\.json$/"
      ],
      "matchStrings": [
        "docker\\.io/otel/opentelemetry-collector-contrib:(?<currentValue>[0-9][0-9A-Za-z.-]+)"
      ]
    },
    {
      "description": "The SeaweedFS image the seaweedfs server runs, pinned in its stage, catalog, and README so a bump is a visible Renovate PR.",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker.io/chrislusf/seaweedfs",
      "managerFilePatterns": [
        "/^workloads/seaweedfs/.+\\.libsonnet$/",
        "/^workloads/seaweedfs/README\\.md$/",
        "/^catalog/annotations\\.libsonnet$/",
        "/^catalog/catalog\\.json$/"
      ],
      "matchStrings": [
        "docker\\.io/chrislusf/seaweedfs:(?<currentValue>[0-9][0-9A-Za-z.-]+)"
      ]
    }
  ]
}
